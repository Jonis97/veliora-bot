TELEGRAM_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
SUPADATA_API_KEY=your_supadata_api_key
SCREENSHOTONE_API_KEY=your_screenshotone_api_key
WEBHOOK_URL=https://your-railway-app.up.railway.app
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=change-me
OPENAI_MODEL=gpt-4o-mini
PORT=8080

# Optional: topic hero image (Wikipedia is tried first without any key)
# UNSPLASH_ACCESS_KEY=
# PEXELS_API_KEY=
# TOPIC_IMAGE_ENABLE_DALLE=0
# Optional: allow Unsplash/Pexels (default off — Wikipedia-only + premium insight fallback)
# TOPIC_IMAGE_ALLOW_STOCK=0
# Vision gate on each hero image (topic match + clarity + premium). Default on when OPENAI is set.
# TOPIC_IMAGE_VISION_VALIDATE=1
# TOPIC_IMAGE_VISION_MODEL=gpt-4o-mini
